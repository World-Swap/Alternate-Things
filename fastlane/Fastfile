default_platform(:ios)

# Builds the iOS app on a macOS runner and uploads it to TestFlight.
# Everything authenticates with an App Store Connect API key — no local Xcode.
#
# Signing: we create/download an Apple Distribution certificate and an App Store
# provisioning profile from the API key, then sign manually. (Automatic signing
# fails on CI because it falls back to a Development profile, which needs a
# registered device.)
#
# Required environment variables (set as GitHub Actions secrets):
#   APP_STORE_CONNECT_KEY_ID     - the API key's Key ID
#   APP_STORE_CONNECT_ISSUER_ID  - the API key's Issuer ID
#   APP_STORE_CONNECT_API_KEY    - base64 of the .p8 key file contents
#   APPLE_TEAM_ID                - your Apple Developer Team ID
platform :ios do
  desc "Build and upload a new build to TestFlight"
  lane :beta do
    app_id  = "com.worldswap.alternatethings"
    project = "ios/App/App.xcodeproj"
    team_id = ENV["APPLE_TEAM_ID"]

    # A dedicated, unlocked keychain so the distribution cert imports cleanly
    # (the default keychain triggers errSecInternalComponent on CI runners).
    keychain_name = "ci.keychain"
    keychain_password = "ci_temp_password"
    keychain_path = File.expand_path("~/Library/Keychains/#{keychain_name}-db")
    delete_keychain(name: keychain_name) if File.exist?(keychain_path)
    create_keychain(
      name: keychain_name,
      password: keychain_password,
      default_keychain: true,
      unlock: true,
      timeout: 3600,
      lock_when_sleeps: false
    )

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY"],
      is_key_content_base64: true
    )

    # Distribution certificate (created if none exists) + App Store profile.
    cert(api_key: api_key, keychain_path: keychain_path, keychain_password: keychain_password)
    sigh(api_key: api_key, app_identifier: app_id, platform: "ios")
    profile_name = lane_context[SharedValues::SIGH_NAME] ||
                   ENV["sigh_#{app_id}_appstore_profile-name"]

    # Manual signing with the distribution profile we just fetched.
    update_code_signing_settings(
      use_automatic_signing: false,
      path: project,
      team_id: team_id,
      code_sign_identity: "Apple Distribution",
      profile_name: profile_name,
      targets: ["App"]
    )

    # Unique, monotonically increasing build number for each CI run.
    build_number = ENV["GITHUB_RUN_NUMBER"] || Time.now.strftime("%Y%m%d%H%M")

    build_app(
      project: project,
      scheme: "App",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "build",
      output_name: "App.ipa",
      clean: true,
      xcargs: "CURRENT_PROJECT_VERSION=#{build_number}",
      export_options: {
        method: "app-store",
        signingStyle: "manual",
        teamID: team_id,
        provisioningProfiles: { app_id => profile_name }
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      skip_submission: true
    )
  end
end
